GROQ_API_KEY=
GROQ_CHAT_MODEL=openai/gpt-oss-120b
GROQ_CHAT_REASONING_EFFORT=high
GROQ_UTILITY_MODEL=openai/gpt-oss-20b
GROQ_UTILITY_REASONING_EFFORT=medium
GROQ_VALIDATION_MODEL=openai/gpt-oss-20b
GROQ_VALIDATION_REASONING_EFFORT=medium
GROQ_WEB_MODEL=openai/gpt-oss-120b
GROQ_WEB_REASONING_EFFORT=high
# Deprecated for one release: role-specific GROQ_* settings take precedence.
# Removed in the next breaking configuration release.
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_REASONING_EFFORT=medium
GROQ_TIMEOUT_SECONDS=60
GROQ_MAX_RETRIES=1
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-4-large
VOYAGE_EMBEDDING_DIMENSIONS=1024
VOYAGE_RERANKER_MODEL=rerank-2.5
VOYAGE_TIMEOUT_SECONDS=30
VOYAGE_MAX_RETRIES=1
SQLITE_PATH=../data/mapping_memory.sqlite
CHROMA_PATH=../data/chroma
MEMORY_ENABLED=true
MEMORY_PATH=../data/memory
